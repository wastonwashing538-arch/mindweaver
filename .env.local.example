# ─────────────────────────────────────────────────────────────────────────────
# 双通道 AI 路由（极简架构，两个绝对隔离的通道）
# ─────────────────────────────────────────────────────────────────────────────

# 【免费通道】DeepSeek 官方 API
DEEPSEEK_OFFICIAL_BASE_URL=https://api.deepseek.com
DEEPSEEK_OFFICIAL_API_KEY=sk-your-deepseek-official-key
FREE_MODEL_ID=deepseek-reasoner

# 【VIP 通道】中转商（OpenAI 兼容格式，支持 Claude）
RELAY_CLAUDE_BASE_URL=https://api.your-relay.com/v1
RELAY_CLAUDE_API_KEY=sk-your-relay-key
VIP_MODEL_ID=anthropic/claude-sonnet-4.6

# 旧变量兼容（未配置上方新变量时自动回退）
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Turnstile（人机验证）
# 本地测试用 always-pass 测试 Key：
#   Site Key:   1x00000000000000000000AA
#   Secret Key: 1x0000000000000000000000000000000AA
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ─────────────────────────────────────────────────────────────────────────────
# Supabase（从 Supabase Dashboard > Project Settings > API 复制）
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI（仅用于免费 Moderation 接口，不调用生成 API）
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-key

# ─────────────────────────────────────────────────────────────────────────────
# Creem 支付
# ─────────────────────────────────────────────────────────────────────────────
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
NEXT_PUBLIC_CREEM_VIP_PRODUCT_ID=
NEXT_PUBLIC_CREEM_APP_URL=https://mindweaver-uztu.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# Upstash Redis（分布式限流，从 console.upstash.com 复制）
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# 监控（可选，不填则不启动）
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=mindweaver
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
