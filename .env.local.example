# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key

# Supabase —— 从 Supabase Dashboard > Project Settings > API 复制
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 仅服务端使用，不要加 NEXT_PUBLIC 前缀
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sentry 错误监控 —— 从 sentry.io > Settings > Projects > Keys 复制
# 不填则 Sentry 不启动，不影响正常运行
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=mindweaver
SENTRY_AUTH_TOKEN=sntrys_...

# PostHog 行为分析 —— 从 posthog.com > Project Settings 复制
# 不填则 PostHog 不启动，不影响正常运行
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
